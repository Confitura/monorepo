    "uuid": "^14.0.0",
    "vue": "^3.5.35",
    "vue-echarts": "^7.0.3",
    "vue-markdown-render": "^2.3.0",
    "vue-router": "^4.6.4",
    "vuetify": "4.0.8"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@nuxt/eslint-config": "^1.15.2",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
