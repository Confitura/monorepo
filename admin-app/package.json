    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.14",
    "vite-plugin-vue-meta-layouts": "^0.6.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "4.1.7",
    "vue-tsc": "^3.3.3"
