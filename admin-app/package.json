    "uuid": "^11.1.0",
    "vue": "^3.5.33",
    "vue-echarts": "^7.0.3",
    "vue-markdown-render": "^2.3.0",
    "vue-router": "^4.6.4",
    "vuetify": "4.0.6"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@nuxt/eslint-config": "^1.15.2",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
