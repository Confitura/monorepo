    "sass-embedded": "^1.98.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.10",
    "vite-plugin-vue-meta-layouts": "^0.6.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "4.1.5",
    "vue-tsc": "^3.2.6"
